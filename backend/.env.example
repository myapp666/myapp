# 环境变量配置示例，复制为 .env 并填写真实值

# MySQL 连接串
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/competitor_tracking

# JWT Secret（运行以下命令生成：python -c "import secrets; print(secrets.token_hex(64))"）
JWT_SECRET=your_jwt_secret_here_at_least_64_bytes_hex

# 监控间隔（分钟）
MONITOR_INTERVAL=60

# Anthropic API Key
AI_API_KEY=your_anthropic_api_key_here

# 允许的前端域名（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
