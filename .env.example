# 环境变量配置示例，复制为 .env.local 并填写真实值

# PostgreSQL 连接串（Vercel PostgreSQL / Prisma Data Proxy）
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# JWT Secret（运行以下命令生成：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"）
JWT_SECRET=your_jwt_secret_here_at_least_64_bytes_hex

# 监控间隔（分钟，用于 vercel.json cron 配置）
MONITOR_INTERVAL=60

# Anthropic API Key
AI_API_KEY=your_anthropic_api_key_here

# Cron 任务鉴权 Secret（运行以下命令生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"）
CRON_SECRET=your_cron_secret_here

